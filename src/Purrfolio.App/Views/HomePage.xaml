<Page
    x:Class="Purrfolio.App.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Purrfolio.App.Models"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Loaded="HomePage_OnLoaded">

    <ScrollViewer>
        <Grid Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock FontSize="30" FontWeight="SemiBold" Text="高净值资产总览" />
                <Button
                    Command="{x:Bind ViewModel.RefreshCommand}"
                    Content="刷新"
                    IsEnabled="{x:Bind ViewModel.IsLoading, Converter={StaticResource InverseBooleanConverter}, Mode=OneWay}" />
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="4">
                <TextBlock Text="总资产净值" Opacity="0.7" />
                <TextBlock FontSize="42" FontWeight="SemiBold" Text="{x:Bind ViewModel.TotalNetWorth, Mode=OneWay, StringFormat='¥{0:N2}'}" />
            </StackPanel>

            <InfoBar
                Grid.Row="2"
                IsOpen="{x:Bind ViewModel.HasDeviationWarning, Mode=OneWay}"
                Severity="Warning"
                IsClosable="False"
                Title="永久组合偏离预警"
                Message="{x:Bind ViewModel.DeviationWarningText, Mode=OneWay}" />

            <Border Grid.Row="3" Padding="16" CornerRadius="12" Background="{StaticResource PortfolioCardBrush}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="10">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="资产环形图" />
                        <Canvas
                            x:Name="DonutCanvas"
                            Width="280"
                            Height="220"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            SizeChanged="ChartCanvas_OnSizeChanged" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="资产类别分布" />
                        <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.DonutSlices, Mode=OneWay}">
                            <muxc:ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:AssetDonutSlice">
                                    <Grid Padding="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Name}" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Value, StringFormat='¥{0:N2}'}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Weight, StringFormat='{}{0:P2}'}" />
                                    </Grid>
                                </DataTemplate>
                            </muxc:ItemsRepeater.ItemTemplate>
                        </muxc:ItemsRepeater>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="4" Padding="16" CornerRadius="12" Background="{StaticResource PortfolioCardBrush}">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="净值曲线与基准对比" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Foreground="#FF4A90E2" Text="● 总资产" />
                        <TextBlock Foreground="#FFE67E22" Text="● 沪深300（归一化）" />
                        <TextBlock Foreground="#FF4CAF50" Text="● CPI（归一化）" />
                    </StackPanel>
                    <Canvas
                        x:Name="TrendCanvas"
                        Height="260"
                        HorizontalAlignment="Stretch"
                        SizeChanged="ChartCanvas_OnSizeChanged" />
                    <TextBlock Opacity="0.75" Text="{x:Bind ViewModel.BenchmarkHintText, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="5" Padding="16" CornerRadius="12" Background="{StaticResource PortfolioCardBrush}">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="百万目标进度" />
                    <ProgressBar Height="16" Maximum="100" Value="{x:Bind ViewModel.GoalProgressPercentage, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind ViewModel.GoalProgressText, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind ViewModel.ProjectionText, Mode=OneWay}" Opacity="0.8" />
                    <TextBlock Text="{x:Bind ViewModel.CountdownText, Mode=OneWay}" Opacity="0.8" />
                    <TextBlock Text="{x:Bind ViewModel.BondPortfolioXirrText, Mode=OneWay, StringFormat='债券仓 XIRR：{0}'}" Opacity="0.8" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

<Page
    x:Class="Purrfolio.App.Views.ManualEntryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock FontSize="30" FontWeight="SemiBold" Text="手动录入投资记录" />
                <TextBlock Opacity="0.8" Text="数据仅保存在本地 SQLite，不上传云端。" />
            </StackPanel>

            <InfoBar
                Grid.Row="1"
                IsOpen="{x:Bind ViewModel.IsStatusOpen, Mode=TwoWay}"
                IsClosable="True"
                Severity="{x:Bind ViewModel.StatusSeverity, Mode=OneWay}"
                Title="{x:Bind ViewModel.StatusTitle, Mode=OneWay}"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />

            <Border Grid.Row="2" Padding="16" CornerRadius="12" Background="{StaticResource PortfolioCardBrush}">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                            <TextBlock Text="资产类别" />
                            <ComboBox
                                ItemsSource="{x:Bind ViewModel.AssetClassOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedAssetClass, Mode=TwoWay}"
                                DisplayMemberPath="Label" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                            <TextBlock Text="资产名称" />
                            <TextBox PlaceholderText="可留空，默认采用资产类别" Text="{x:Bind ViewModel.AssetName, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Spacing="6">
                            <TextBlock Text="交易日期" />
                            <DatePicker Date="{x:Bind ViewModel.TradeDate, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                            <TextBlock Text="数量" />
                            <TextBox Text="{x:Bind ViewModel.QuantityText, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                            <TextBlock Text="成交价" />
                            <TextBox Text="{x:Bind ViewModel.UnitPriceText, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Spacing="6">
                            <TextBlock Text="费用" />
                            <TextBox Text="{x:Bind ViewModel.FeesText, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Spacing="8"
                            Visibility="{x:Bind ViewModel.ShowBondFields, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock FontWeight="SemiBold" Text="债券扩展字段" />
                            <Grid ColumnSpacing="12" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Width="220" Spacing="6">
                                    <TextBlock Text="应计利息" />
                                    <TextBox Text="{x:Bind ViewModel.AccruedInterestText, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Width="220" Spacing="6">
                                    <TextBlock Text="票面利率（0~1）" />
                                    <TextBox Text="{x:Bind ViewModel.CouponRateText, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Width="220" Spacing="6">
                                    <TextBlock Text="派息频率" />
                                    <ComboBox
                                        ItemsSource="{x:Bind ViewModel.CouponFrequencyOptions, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedCouponFrequency, Mode=TwoWay}"
                                        DisplayMemberPath="Label" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Width="220" Spacing="6">
                                    <TextBlock Text="到期日" />
                                    <DatePicker Date="{x:Bind ViewModel.MaturityDate, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>
                            <CheckBox Content="标记为超长期特别国债" IsChecked="{x:Bind ViewModel.IsSpecialGovernmentBond, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            Command="{x:Bind ViewModel.SaveCommand}"
                            Content="保存记录"
                            MinWidth="120"
                            IsEnabled="{x:Bind ViewModel.IsSaving, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
                        <ProgressRing Width="24" Height="24" IsActive="{x:Bind ViewModel.IsSaving, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

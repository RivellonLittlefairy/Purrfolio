<Page
    x:Class="Purrfolio.App.Views.OcrImportPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Purrfolio.App.Models"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock x:Name="PageTitleText" FontSize="30" FontWeight="SemiBold" Text="截图识别自动录入" />
                <TextBlock Opacity="0.8" Text="上传截图后调用 MiniMax OCR 识别投资字段，校对后可批量写入本地 SQLite。" />
            </StackPanel>

            <InfoBar
                Grid.Row="1"
                IsOpen="{x:Bind ViewModel.IsStatusOpen, Mode=TwoWay}"
                IsClosable="True"
                Severity="{x:Bind ViewModel.StatusSeverity, Mode=OneWay}"
                Title="{x:Bind ViewModel.StatusTitle, Mode=OneWay}"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />

            <Border Grid.Row="2" Padding="16" CornerRadius="12" Background="{StaticResource PortfolioCardBrush}">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="截图与服务参数" />

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            PlaceholderText="选择或粘贴截图绝对路径"
                            Text="{x:Bind ViewModel.ImagePath, Mode=TwoWay}" />
                        <Button
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            AccessKey="B"
                            Click="BrowseImageButton_OnClick"
                            Content="选择截图"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
                    </Grid>

                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="280" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                            <TextBlock Text="MiniMax Endpoint" />
                            <TextBox Text="{x:Bind ViewModel.Endpoint, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                            <TextBlock Text="MiniMax API Key" />
                            <TextBox Text="{x:Bind ViewModel.ApiKey, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Spacing="6">
                            <TextBlock Text="Model" />
                            <TextBox Text="{x:Bind ViewModel.Model, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" Spacing="10" VerticalAlignment="Center">
                            <CheckBox Content="Authorization 使用 Bearer Token" IsChecked="{x:Bind ViewModel.UseBearerToken, Mode=TwoWay}" />
                            <Button
                                AccessKey="A"
                                Command="{x:Bind ViewModel.AnalyzeCommand}"
                                Content="开始识别"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"
                                MinWidth="140" />
                            <ProgressRing Width="26" Height="26" IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Padding="16" CornerRadius="12" Background="{StaticResource PortfolioCardBrush}">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="识别草稿（可编辑后导入）" />
                        <Button AccessKey="L" Command="{x:Bind ViewModel.SelectAllCommand}" Content="全选" />
                        <Button AccessKey="C" Command="{x:Bind ViewModel.ClearSelectionCommand}" Content="清空选择" />
                        <Button
                            AccessKey="I"
                            Command="{x:Bind ViewModel.ImportSelectedCommand}"
                            Content="导入选中"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
                    </StackPanel>

                    <TextBlock Opacity="0.75" Text="资产类别建议填写：Stocks / Gold / GovernmentBonds / Cash；日期建议 yyyy-MM-dd。" />

                    <Grid MinWidth="1460" Padding="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="选中" />
                        <TextBlock Grid.Column="1" Text="名称" />
                        <TextBlock Grid.Column="2" Text="资产类别" />
                        <TextBlock Grid.Column="3" Text="交易日" />
                        <TextBlock Grid.Column="4" Text="数量" />
                        <TextBlock Grid.Column="5" Text="价格" />
                        <TextBlock Grid.Column="6" Text="费用" />
                        <TextBlock Grid.Column="7" Text="票息" />
                        <TextBlock Grid.Column="8" Text="频率" />
                        <TextBlock Grid.Column="9" Text="到期日" />
                        <TextBlock Grid.Column="10" Text="应计息" />
                        <TextBlock Grid.Column="11" Text="特别债" />
                        <TextBlock Grid.Column="12" Text="置信度" HorizontalAlignment="Right" />
                    </Grid>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled">
                        <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.Drafts, Mode=OneWay}">
                            <muxc:ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:OcrInvestmentDraft">
                                    <Grid Padding="0,8" MinWidth="1460">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" HorizontalAlignment="Center" />
                                        <TextBox Grid.Column="1" Margin="4,0" Text="{x:Bind Name, Mode=TwoWay}" />
                                        <TextBox Grid.Column="2" Margin="4,0" Text="{x:Bind AssetClass, Mode=TwoWay}" />
                                        <TextBox Grid.Column="3" Margin="4,0" Text="{x:Bind TradeDate, Mode=TwoWay}" />
                                        <TextBox Grid.Column="4" Margin="4,0" Text="{x:Bind QuantityText, Mode=TwoWay}" />
                                        <TextBox Grid.Column="5" Margin="4,0" Text="{x:Bind UnitPriceText, Mode=TwoWay}" />
                                        <TextBox Grid.Column="6" Margin="4,0" Text="{x:Bind FeesText, Mode=TwoWay}" />
                                        <TextBox Grid.Column="7" Margin="4,0" Text="{x:Bind CouponRateText, Mode=TwoWay}" />
                                        <TextBox Grid.Column="8" Margin="4,0" Text="{x:Bind CouponFrequency, Mode=TwoWay}" />
                                        <TextBox Grid.Column="9" Margin="4,0" Text="{x:Bind MaturityDate, Mode=TwoWay}" />
                                        <TextBox Grid.Column="10" Margin="4,0" Text="{x:Bind AccruedInterestText, Mode=TwoWay}" />
                                        <CheckBox Grid.Column="11" IsChecked="{x:Bind IsSpecialGovernmentBond, Mode=TwoWay}" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="12" VerticalAlignment="Center" HorizontalAlignment="Right" Text="{x:Bind Confidence, Mode=OneWay, StringFormat='{}{0:P0}'}" />
                                    </Grid>
                                </DataTemplate>
                            </muxc:ItemsRepeater.ItemTemplate>
                        </muxc:ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
